{
  "name": "travel-booking",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack --hostname 127.0.0.1",
    "build": "prisma generate && next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:db:push": "prisma db push",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:seed": "node prisma/seed.js",
    "prisma:generate:postgres": "prisma generate --schema=prisma/schema.postgres.prisma",
    "prisma:migrate:postgres": "prisma migrate dev --schema=prisma/schema.postgres.prisma --name init",
    "prisma:db:push:postgres": "prisma db push --schema=prisma/schema.postgres.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.8.0",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-tabs": "^1.1.15",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "swiper": "^12.2.0",
    "tailwind-merge": "^3.6.0",
    "jsonwebtoken": "^9.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/jsonwebtoken": "^9.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prisma": "^5.8.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^1.5.8"
  }
}
